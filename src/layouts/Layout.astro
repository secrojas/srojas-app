---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Sebastian Rojas — Desarrollador Full Stack',
  description = 'Desarrollador full stack especializado en arquitecturas limpias, Laravel y Vue 3. Creador de Hub, TalentTrack y MiEntreno.',
  ogImage,
} = Astro.props;

const siteUrl = 'https://srojas.app';
const currentUrl = new URL(Astro.url.pathname, siteUrl).href;
const imageUrl = ogImage ? new URL(ogImage, siteUrl).href : `${siteUrl}/og-image.png`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Sebastian Rojas" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="googlebot" content="index, follow" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/og-image.png" />

    <!-- Canonical -->
    <link rel="canonical" href={currentUrl} />

    <!-- Open Graph — Facebook / LinkedIn / WhatsApp -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Sebastian Rojas — Desarrollador Full Stack" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:site_name" content="Sebastian Rojas" />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@secrojas" />
    <meta name="twitter:creator" content="@secrojas" />
    <meta name="twitter:url" content={currentUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content="Sebastian Rojas — Desarrollador Full Stack" />

    <!-- Theme color -->
    <meta name="theme-color" content="#0a0a0f" />
    <meta name="msapplication-navbutton-color" content="#0a0a0f" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Sebastian Rojas",
      "url": siteUrl,
      "image": `${siteUrl}/og-image.png`,
      "jobTitle": "Desarrollador Full Stack",
      "description": description,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Mar del Plata",
        "addressRegion": "Buenos Aires",
        "addressCountry": "AR"
      },
      "knowsAbout": ["PHP", "Laravel", "Vue.js", "TypeScript", "Astro", "TailwindCSS", "MySQL", "Inertia.js"],
      "sameAs": [
        "https://github.com/secrojas",
        "https://www.linkedin.com/in/secrojas/",
        "https://srojasweb.dev"
      ]
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Sebastian Rojas",
      "url": siteUrl,
      "description": description,
      "author": {
        "@type": "Person",
        "name": "Sebastian Rojas"
      }
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
